@model List<benhvien.Models.BloodRequest>

@{
    ViewData["Title"] = "Danh sách cần máu";
    Layout = "_Layout";
}

<style>
    .br-page {
        background: #f8f9fa;
        min-height: 80vh;
        padding: 40px 0 60px;
    }

    .br-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 32px;
    }

    .br-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: #1a1a1a;
        margin: 0;
    }

        .br-title span {
            color: #d32f2f;
        }

    .btn-history {
        height: 42px;
        padding: 0 20px;
        border-radius: 8px;
        border: 2px solid #d32f2f;
        color: #d32f2f;
        font-weight: 600;
        font-size: 0.88rem;
        background: white;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }

        .btn-history:hover {
            background: #d32f2f;
            color: white;
        }

    /* Cards */
    .blood-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.07);
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
        background: white;
    }

        .blood-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.12);
        }

    .card-top {
        background: linear-gradient(135deg, #c62828, #e53935);
        padding: 20px 20px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .blood-type-badge {
        font-size: 2rem;
        font-weight: 900;
        color: white;
        letter-spacing: 1px;
        line-height: 1;
    }

    .urgent-badge {
        background: rgba(255,255,255,0.2);
        border: 1.5px solid rgba(255,255,255,0.5);
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        padding: 4px 10px;
        border-radius: 20px;
        text-transform: uppercase;
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.65;
        }
    }

    .card-body {
        padding: 20px;
    }

    .qty-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 12px;
    }

    .qty-icon {
        width: 32px;
        height: 32px;
        background: #ffebee;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .qty-text {
        font-size: 0.92rem;
        color: #333;
        font-weight: 500;
    }

    .qty-num {
        font-weight: 800;
        color: #d32f2f;
    }

    .desc-text {
        font-size: 0.87rem;
        color: #666;
        line-height: 1.6;
        margin-bottom: 18px;
        min-height: 40px;
    }

    .btn-donate {
        background: linear-gradient(135deg, #c62828, #d32f2f);
        color: white;
        border: none;
        border-radius: 8px;
        height: 42px;
        width: 100%;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.2s;
        box-shadow: 0 3px 10px rgba(211,47,47,0.3);
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .btn-donate:hover {
            background: linear-gradient(135deg, #b71c1c, #c62828);
            color: white;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(211,47,47,0.4);
        }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #aaa;
    }

        .empty-state .empty-icon {
            font-size: 4rem;
            margin-bottom: 16px;
            display: block;
        }

        .empty-state p {
            font-size: 1rem;
            margin: 0;
        }
</style>

<div class="br-page">
    <div class="container">
        <div class="br-header">
            <h2 class="br-title">Danh sách <span>cần máu</span></h2>
            <a asp-controller="Donation" asp-action="History" class="btn-history">
                📋 Xem lịch sử đăng ký
            </a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <span class="empty-icon">🩸</span>
                <p>Hiện chưa có yêu cầu cần máu nào.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-md-4 col-sm-6">
                        <div class="blood-card">
                            <div class="card-top">
                                <div class="blood-type-badge">@item.BloodType</div>
                                @if (item.IsUrgent)
                                {
                                    <span class="urgent-badge">🚨 Khẩn cấp</span>
                                }
                            </div>
                            <div class="card-body">
                                <div class="qty-row">
                                    <div class="qty-icon">👥</div>
                                    <div class="qty-text">
                                        Cần <span class="qty-num">@item.QuantityNeeded</span> người hiến
                                    </div>
                                </div>
                                <p class="desc-text">@item.Description</p>
                                <a asp-controller="Donation"
                                   asp-action="BloodRegister"
                                   asp-route-id="@item.Id"
                                   class="btn-donate">
                                    Đăng ký hiến máu
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
